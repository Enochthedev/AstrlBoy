# AI
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=astrlboy
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# Scraping & Search
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# Social — X (OAuth 1.0a for posting + OAuth 2.0 Bearer for streaming)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Social — LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# Email — SMTP outbound (Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Email — IMAP inbound
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
AGENT_EMAIL=agent@astrlboy.xyz

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Primary DB (agent's own data)
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# R2 (training data + raw dumps)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=astrlboy-data
R2_ENDPOINT_URL=

# Redis (Upstash)
REDIS_URL=

# Agent control
AGENT_PAUSED=false
AGENT_NAME=astrlboy
AGENT_HANDLE=@astrlboy_
LOG_LEVEL=INFO

# Budget — X API cost controls (pay-per-use tier)
# Monthly budget is auto-split across operation types by priority weight.
# Set to 0 to disable budget enforcement.
X_DAILY_TWEET_CAP=15                   # max tweets (posts + replies) per day
X_MONTHLY_BUDGET_CENTS=500             # monthly X API budget in cents ($5.00)
X_FOLLOWER_PAGE_CAP=3                  # max follower pagination pages (3 × 100 = 300 users)
X_STREAM_ENABLED=false                 # KEEP FALSE on pay-per-use — each streamed tweet = $0.005 read
X_STREAM_DAILY_CAP=200                 # max tweets to process per day from stream (0 = unlimited)
